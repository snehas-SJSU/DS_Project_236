{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "1. Docker: Compose Up (infra)",
      "type": "shell",
      "command": "docker compose up -d",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared", "focus": true }
    },
    {
      "label": "2. Docker: Compose Down",
      "type": "shell",
      "command": "docker compose down",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "3. npm: Bootstrap (install all Node deps)",
      "type": "shell",
      "command": "npm run bootstrap",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "4. npm: Start all services (gateway + APIs + workers)",
      "type": "shell",
      "command": "npm run start:all",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "linkedin-stack",
        "pattern": { "regexp": ".", "file": 1, "location": 1, "message": 1 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "API Gateway running on port"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "5. Frontend: Vite dev (port 3000)",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": ".", "file": 1, "location": 1, "message": 1 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "localhost:3000"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "6. AI: Uvicorn (FastAPI port 8001)",
      "type": "shell",
      "command": "python3 -m uvicorn main:app --reload --host 127.0.0.1 --port 8001",
      "options": { "cwd": "${workspaceFolder}/services/ai-service" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "uvicorn",
        "pattern": { "regexp": ".", "file": 1, "location": 1, "message": 1 },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Uvicorn running on"
        }
      },
      "presentation": { "reveal": "always", "panel": "dedicated", "focus": true }
    },
    {
      "label": "7. Seed: Demo member M-123 (needs Kafka + member worker)",
      "type": "shell",
      "command": "npm run seed:member",
      "options": { "cwd": "${workspaceFolder}" },
      "group": "test",
      "presentation": { "reveal": "always", "panel": "shared" }
    }
  ]
}

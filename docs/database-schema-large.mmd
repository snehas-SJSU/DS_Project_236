    MEMBERS ||--o{ CONNECTION_REQUESTS : receives
    MEMBERS ||--o{ CONNECTIONS : connects
    THREADS ||--o{ THREAD_PARTICIPANTS : has
    MEMBERS ||--o{ THREAD_PARTICIPANTS : joins

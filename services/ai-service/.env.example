# Copy this file to `.env` in the same folder (services/ai-service/) and fill in secrets.
# `.env` is gitignored. Uvicorn loads `.env` automatically when python-dotenv is installed.

# Required for Groq-powered resume parse, outreach drafts, and career coach (optional otherwise).
GROQ_API_KEY=

# Optional Groq chat model (see Groq console docs for current model ids).
# AI_GROQ_MODEL=llama-3.1-8b-instant

# Optional: override default User-Agent on outbound HTTP (Groq/Cloudflare may block Python-urllib’s default).
# AI_HTTP_USER_AGENT=LinkedInAgenticAI/1.0 (Python)

# Optional: OpenAI / Gemini embeddings for match scoring (otherwise hashed fallback).
# AI_EMBEDDING_PROVIDER=hashed
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# When true, do not fall back to bundled candidate/job fixtures: Member/Job HTTP APIs must return data
# (503 LIVE_DATA_REQUIRED if not). Use for graded demos against the real platform.
# AI_REQUIRE_LIVE_DATA=false

# Gateway-relative member/job fetch URLs (defaults match local gateway on 4000).
# AI_MEMBER_API_URL=http://127.0.0.1:4000/api/members/get
# AI_JOB_API_URL=http://127.0.0.1:4000/api/jobs/get
# Candidate sourcing (POST /ai/tasks/submit with candidate_source):
# AI_APPLICATIONS_BY_JOB_URL=http://127.0.0.1:4000/api/applications/byJob
# AI_MEMBERS_SEARCH_URL=http://127.0.0.1:4000/api/members/search
# AI_MEMBERS_SEARCH_MAX=40
# Optional skills microservice base URL. If set, supervisor calls skills over HTTP first.
# AI_SKILLS_BASE_URL=http://127.0.0.1:8018

# AI_CANDIDATE_PROFILES_PATH=
# AI_JOB_PROFILES_PATH=

# REDIS_URL=redis://127.0.0.1:6379/0
# MONGO_URL=mongodb://127.0.0.1:27017
# MONGO_DB=linkedin_sim
# MONGO_AI_TASKS_COLLECTION=ai_tasks
# MONGO_AI_TASK_EVENTS_COLLECTION=ai_task_events

# AI_SHORTLIST_HITL_REQUIRED=false
# AI_SEND_TOPIC=outreach.requests
# After approval, run the outreach consumer (messaging-service) to post messages:
#   npm run dev:outreach-worker
# AI_CONSUMER_GROUP=ai-service-supervisor
